#include <stdio.h>
#include <stdlib.h>
#include <conio.h>

// Структура для узла односвязного списка
typedef struct Node {
    int data;
    struct Node* next;
} Node;

typedef struct MenuItem {
    char text[50];
    int id;
} MenuItem;

//Создаем новый узел односвязного списка
Node* createNode(int data) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    if (newNode == NULL) {
        printf("Memory error!\n");
        return NULL;
    }
    newNode->data = data;
    newNode->next = NULL;
    return newNode;
}

//Получает длину списка.
int getListLength(Node* head) {
    int length = 0;
    Node* current = head;
    while (current != NULL) {
        length++;
        current = current->next;
    }
    return length;
}

/**
 * Вставляет элемент по указанному индексу.
 * Если индекс = 0 - вставка в начало
 * Если индекс = длина списка - вставка в конец
 */
void insertAtIndex(Node** head, int data, int index) {
    Node* newNode = createNode(data);
    if (newNode == NULL) return;
    
    // Получаем длину списка
    int length = getListLength(*head);
    
    // Случай 1: Вставка в начало (или в пустой список)
    if (index == 0) {
        newNode->next = *head;
        *head = newNode;
        printf("Element %d inserted at index %d (beginning).\n", data, index);
        return;
    }
    
    // Случай 2: Вставка в середину или конец
    Node* current = *head;
    Node* prev = NULL;
    
    // Переходим к нужному индексу
    for (int i = 0; i < index; i++) {
        prev = current;
        current = current->next;
    }
    
    // Вставляем между prev и current
    prev->next = newNode;
    newNode->next = current;
    
    printf("Element %d inserted at index %d.\n", data, index);
}

//Удаляет элемент по указанному индексу.
void deleteByIndex(Node** head, int index) {
    if (*head == NULL) {
        printf("List is empty!\n");
        return;
    }
    
    int length = getListLength(*head);
    
    Node* current = *head;
    Node* prev = NULL;
    
    // Случай 1: Удаление первого элемента
    if (index == 0) {
        *head = current->next;
        printf("Element %d at index %d deleted.\n", current->data, index);
        free(current);
        return;
    }
    
    // Случай 2: Удаление из середины или конца
    // Переходим к нужному индексу
    for (int i = 0; i < index; i++) {
        prev = current;
        current = current->next;
    }
    
    // "Вырезаем" элемент
    prev->next = current->next;
    printf("Element %d at index %d deleted.\n", current->data, index);
    free(current);
}

//Ищет элемент по индексу и возвращает его значение.
int searchByIndex(Node* head, int index) {
        if (head == NULL) {
        return -1; 
    }
    int length = getListLength(head);
    
    Node* current = head;
    
    // Переходим к нужному индексу
    for (int i = 0; i < index; i++) {
        current = current->next;
    }
    return current->data;
}

void showElementByIndex(Node* head, int index) {
    int result = searchByIndex(head, index);
    
    //Обрабатываем специальные знач-е
    if (result == -1) {
        printf("List is empty!\n");
    } else {
        printf("Element at index %d: %d\n", index, result);
    }
}

//Удаляет все элементы, значение которых больше указанного
void deleteGreaterThan(Node** head, int value) {
    if (*head == NULL) return;
    
    int length = getListLength(*head);
    int deleted = 0;
    
    for (int i = length - 1; i >= 0; i--) {
        int elementValue = searchByIndex(*head, i);
        if (elementValue > value) {
            deleteByIndex(head, i);
            deleted++;
        }
    }
    
    printf("Elements greater than %d deleted\n", value, deleted);
}

// Удаляет все элементы, значение которых меньше указанного 
void deleteLessThan(Node** head, int value) {
    if (*head == NULL) return;
    
    int length = getListLength(*head);
    int deleted = 0;
    
    for (int i = length - 1; i >= 0; i--) {
        int elementValue = searchByIndex(*head, i);
        if (elementValue < value) {
            deleteByIndex(head, i);
            deleted++;
        }
    }
    
    printf("Elements less than %d deleted\n", value, deleted);
}

// Удаляет все элементы, значение которых равно указанному
void deleteEqualTo(Node** head, int value) {
    if (*head == NULL) return;
    
    int length = getListLength(*head);
    int deleted = 0;
    
    for (int i = length - 1; i >= 0; i--) {
        int elementValue = searchByIndex(*head, i);
        if (elementValue == value) {
            deleteByIndex(head, i);
            deleted++;
        }
    }
    
    printf("Elements equal to %d deleted\n", value, deleted);
}

//Выводит все элементы списка на экран.
void displayList(Node* head) {
    if (head == NULL) {
        printf("List is empty!\n");
        return;
    }
    
    Node* temp = head;
    int count = 0;
    printf("List contents (index: value):\n");
    while (temp != NULL) {
        printf("[%d]: %d -> ", count, temp->data);
        temp = temp->next;
        count++;
    }
    printf("END\n");
    printf("Total elements: %d\n", count);
}

//Полностью освобождает всю память, занятую односвязным списком.
void freeList(Node** head) {
    Node* current = *head;
    Node* next;
    
    while (current != NULL) {
        next = current->next;
        free(current);
        current = next;
    }
    *head = NULL;
    printf("List cleared.\n");
}

void displayMenu(MenuItem menu[], int size, int selected) {
    system("cls");
    
    for (int i = 0; i < size; i++) {
        if (i == selected) {
            printf("-> ");
        } else {
            printf("   ");
        }
        printf("%s\n", menu[i].text);
    }
}

int main() {
    Node* head = NULL;
    int value, index;
    int menuSize = 9;  
    int selected = 0;
    int key;
    MenuItem menu[] = {
        {"1. Create new list (clear old)"},
        {"2. Insert element at index"},        // вставка
        {"3. Delete element by index"},        // Удаление
        {"4. Search element by index"},        // Поиск 
        {"5. Display all elements"},
        {"6. Delete elements GREATER than value"},
        {"7. Delete elements LESS than value"},
        {"8. Delete elements EQUAL to value"},
        {"9. Exit"}
    };
    
    do {
        displayMenu(menu, menuSize, selected);
        
        key = getch();
        if (key == 0 || key == 224) {
            key = getch();
            switch(key) {
                case 72:
                    selected = (selected - 1 + menuSize) % menuSize;
                    break;
                case 80:
                    selected = (selected + 1) % menuSize;
                    break;
            }
            continue;
        }
        
        if (key == 13) {
            system("cls");
            switch(selected) {
                case 0: // Создание нового списка
                    freeList(&head);
                    printf("Enter number of elements: ");
                    scanf("%d", &value);
                    printf("Enter %d elements:\n", value);
                    for (int i = 0; i < value; i++) {
                        int elem;
                        scanf("%d", &elem);
                        // Вставляем последовательно в конец
                        insertAtIndex(&head, elem, i);
                    }
                    printf("List created successfully.\n");
                    break;
                    
                case 1: // Вставка элемента по индексу
                    if (head == NULL) {
                        printf("List is empty. Inserting at index 0.\n");
                        printf("Enter value to insert: ");
                        scanf("%d", &value);
                        insertAtIndex(&head, value, 0);
                    } else {
                        printf("Current list length: %d\n", getListLength(head));
                        printf("Enter index (0-%d): ", getListLength(head));
                        scanf("%d", &index);
                        printf("Enter value to insert: ");
                        scanf("%d", &value);
                        insertAtIndex(&head, value, index);
                    }
                    break;
                    
                case 2: // Удаление элемента по индексу
                    if (head == NULL) {
                        printf("List is empty!\n");
                    } else {
                        printf("Current list length: %d\n", getListLength(head));
                        printf("Enter index to delete (0-%d): ", getListLength(head)-1);
                        scanf("%d", &index);
                        deleteByIndex(&head, index);
                    }
                    break;
                    
                case 3: // Поиск элемента по индексу
                    if (head == NULL) {
                        printf("List is empty!\n");
                    } else {
                        printf("Current list length: %d\n", getListLength(head));
                        printf("Enter index to search (0-%d): ", getListLength(head)-1);
                        scanf("%d", &index);
                        showElementByIndex(head, index);
                    }
                    break;
                    
                case 4: // Отображение всех элементов
                    displayList(head);
                    break;
                    
                case 5: // Удаление элементов БОЛЬШЕ указанного значения
                    printf("Enter value: ");
                    scanf("%d", &value);
                    deleteGreaterThan(&head, value);
                    break;
                    
                case 6: // Удаление элементов МЕНЬШЕ указанного значения
                    printf("Enter value: ");
                    scanf("%d", &value);
                    deleteLessThan(&head, value);
                    break;
                    
                case 7: // Удаление элементов РАВНЫХ указанному значению
                    printf("Enter value: ");
                    scanf("%d", &value);
                    deleteEqualTo(&head, value);
                    break;
                    
                case 8: // Выход из программы
                    printf("Exiting program...\n");
                    break;
            }
            if (selected != 8) {
                printf("\nPress any key to return to menu...");
                getch();
            }
        }
        
    } while (selected != 8 || key != 13);
    
    freeList(&head);
    return 0;
}
